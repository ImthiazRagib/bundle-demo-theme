<section class="rich-text rich-text--{{ section.settings.width }}">
  <div class="rich-text__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="rich-text__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="rich-text__body rte">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_url }}" class="rich-text__btn">{{ section.settings.btn_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "Section width",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "medium", "label": "Medium" },
        { "value": "wide", "label": "Wide" }
      ],
      "default": "medium"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Rich Text"
    }
  ]
}
{% endschema %}
