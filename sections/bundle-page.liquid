    {
      "type": "collection",
      "id": "collection",
      "label": "Products Collection",
      "info": "Products customers can add to their bundle. Leave blank to show demo products."
    },
    {
      "type": "header",
      "content": "One Plan"
    },
    {
      "type": "number",
      "id": "price_one",
