    {
      "type": "number",
      "id": "variant_id_one",
      "label": "Bundle Variant ID",
      "info": "Shopify Variant ID for the 'One' bundle product. Find it in Products > your bundle product > copy variant ID."
    },
    {
      "type": "header",
      "content": "Two Plan"
    },
    {
      "type": "number",
      "id": "price_two",
      "label": "Price (cents)",
      "default": 4999,
      "info": "e.g. 4999 = $49.99"
    },
    {
      "type": "number",
      "id": "variant_id_two",
      "label": "Bundle Variant ID",
      "info": "Shopify Variant ID for the 'Two' bundle product."
    },
    {
      "type": "header",
      "content": "Infinity Plan"
    },
    {
      "type": "number",
      "id": "price_infinity",
      "label": "Price (cents)",
      "default": 6999,
      "info": "e.g. 6999 = $69.99"
    },
    {
      "type": "number",
      "id": "variant_id_infinity",
      "label": "Bundle Variant ID",
      "info": "Shopify Variant ID for the 'Infinity' bundle product."
    }
  ],
  "presets": [
    {
      "name": "Bundle Builder"
    }
  ]
}
{% endschema %}
