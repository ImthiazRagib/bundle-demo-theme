{% comment %}
  ============================================================
  SHOPIFY BUNDLE BUILDER — sections/bundle-builder.liquid
  Last deploy: 2026-04-01T20:08 — fix preview fade + ghost-click guard
  ============================================================
  Installation:
    1. Copy this file into your theme's sections/ folder.
    2. Copy bundle-builder.css and bundle-builder.js into assets/.
    3. Add  {% section 'bundle-builder' %}  to your desired template
       (e.g. templates/page.bundle.liquid or templates/index.liquid).
    4. In the Shopify Theme Editor, set your product variant IDs
       and any image URLs via the section schema settings below.
    5. Update BB_VARIANTS in the <script> block at the bottom
       with your real Shopify product variant IDs.
  ============================================================
{% endcomment %}

{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}

<div class="bb-wrap-outer">
  <div class="bb-wrap" id="bb-root" data-media-url="{{ 'bundle-builder-media.json' | asset_url }}">
    {%- comment -%} ══ SCREEN 0: BUNDLE SELECTOR ═══════════════════ {%- endcomment -%}
    <section id="bb-screen-selector" class="bb-screen is-active" aria-label="Scegli il pacchetto">
      <div class="bb-selector">
        <h1 class="bb-selector__title">Scegli il pacchetto</h1>
        <p class="bb-selector__sub">
          Crea la tua combinazione personalizzata di cinture.<br>
          Scegli il set che fa per te e componi ogni cintura.
        </p>

        <article
          class="bb-bundle-card"
          data-type="single"
          data-select-bundle="single"
          role="button"
          tabindex="0"
          aria-label="Single Set Belt"
        >
          <div class="bb-bundle-card__icon">
            {%- if section.settings.img_single -%}
              <img src="{{ section.settings.img_single | img_url: '200x200' }}" alt="Single Set Belt" loading="lazy">
            {%- else -%}
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none">
                <rect x="8" y="17" width="24" height="6" rx="3" fill="#b8860b" opacity=".85"/><rect x="17" y="12" width="6" height="16" rx="2" fill="#b8860b"/>
              </svg>
            {%- endif -%}
          </div>
          <div class="bb-bundle-card__body">
            <div class="bb-bundle-card__name">Single Set Belt</div>
            <div class="bb-bundle-card__includes">Include 1 cintura — La cintura perfetta composta su misura.</div>
            <div>
              <span class="bb-bundle-card__price">{{ section.settings.price_single | default: '€ 49,99' }}</span>
            </div>
            <button
              class="bb-bundle-card__cta"
              data-action="start"
              data-select-bundle="single"
              onclick="BundleBuilder.selectBundleType('single')"
            >
              Inizia a comporre →
            </button>
          </div>
        </article>

        <article
          class="bb-bundle-card"
          data-type="double"
          data-select-bundle="double"
          role="button"
          tabindex="0"
          aria-label="Double Set Belt"
        >
          <div class="bb-bundle-card__icon">
            {%- if section.settings.img_double -%}
              <img src="{{ section.settings.img_double | img_url: '200x200' }}" alt="Double Set Belt" loading="lazy">
            {%- else -%}
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none">
                <rect x="6" y="14" width="22" height="5" rx="2.5" fill="#b8860b" opacity=".7"/><rect x="6" y="21" width="22" height="5" rx="2.5" fill="#b8860b"/><rect x="16" y="10" width="5" height="20" rx="2" fill="#b8860b" opacity=".5"/>
              </svg>
            {%- endif -%}
          </div>
          <div class="bb-bundle-card__body">
            <div class="bb-bundle-card__name">Double Set Belt</div>
            <div class="bb-bundle-card__includes">Include 2 cinture — Due cinture personalizzate, una per ogni look.</div>
            <div>
              <span class="bb-bundle-card__price">{{ section.settings.price_double | default: '€ 79,99' }}</span>
              <span class="bb-bundle-card__badge">Risparmi €19,99</span>
            </div>
            <button
              class="bb-bundle-card__cta"
              data-action="start"
              data-select-bundle="double"
              onclick="BundleBuilder.selectBundleType('double')"
            >
              Inizia a comporre →
            </button>
          </div>
        </article>

        <article
          class="bb-bundle-card"
          data-type="triple"
          data-select-bundle="triple"
          role="button"
          tabindex="0"
          aria-label="Triple Set Belt"
        >
          <div class="bb-bundle-card__icon">
            {%- if section.settings.img_triple -%}
              <img src="{{ section.settings.img_triple | img_url: '200x200' }}" alt="Triple Set Belt" loading="lazy">
            {%- else -%}
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none">
                <circle cx="10" cy="20" r="5" fill="#b8860b" opacity=".5"/>
                <circle cx="20" cy="20" r="5" fill="#b8860b" opacity=".75"/>
                <circle cx="30" cy="20" r="5" fill="#b8860b" opacity=".9"/>
              </svg>
            {%- endif -%}
          </div>
          <div class="bb-bundle-card__body">
            <div class="bb-bundle-card__name">Triple Set Belt</div>
            <div class="bb-bundle-card__includes">Include 3 cinture — Configura tutte e tre insieme.</div>
            <div>
              <span class="bb-bundle-card__price">{{ section.settings.price_triple | default: '€ 99,99' }}</span>
              <span class="bb-bundle-card__badge">Risparmi €49,98</span>
            </div>
            <button
              class="bb-bundle-card__cta"
              data-action="start"
              data-select-bundle="triple"
              onclick="BundleBuilder.selectBundleType('triple')"
            >
              Inizia a comporre →
            </button>
          </div>
        </article>

        <article
          class="bb-bundle-card"
          data-type="infinity"
          data-select-bundle="infinity"
          role="button"
          tabindex="0"
          aria-label="Infinity Set Belt"
        >
          <div class="bb-bundle-card__icon">
            {%- if section.settings.img_infinity -%}
              <img src="{{ section.settings.img_infinity | img_url: '200x200' }}" alt="Infinity Set Belt" loading="lazy">
            {%- else -%}
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none">
                <path d="M8 20c0-3.3 2.7-6 6-6s6 3 8 6-2.7 6-8 6-6-2.7-6-6z" fill="#b8860b" opacity=".7"/>
                <path d="M20 20c0-3 2.7-6 6-6s6 2.7 6 6-2.7 6-6 6-6-3-8-6z" fill="#b8860b"/>
              </svg>
            {%- endif -%}
          </div>
          <div class="bb-bundle-card__body">
            <div class="bb-bundle-card__name">Infinity Set Belt</div>
            <div class="bb-bundle-card__includes">Include 3 cinture — Il set definitivo, aggiungi una alla volta.</div>
            <div>
              <span class="bb-bundle-card__price">{{ section.settings.price_infinity | default: '€ 99,99' }}</span>
              <span class="bb-bundle-card__badge">Best Value</span>
            </div>
            <button
              class="bb-bundle-card__cta"
              data-action="start"
              data-select-bundle="infinity"
              onclick="BundleBuilder.selectBundleType('infinity')"
            >
              Inizia a comporre →
            </button>
          </div>
        </article>

        <p style="font-size:11px;color:#999;text-align:center;margin-top:8px;">
          ✦ Fai a intervalli (interrompibili) · Reso gratuito · Consegna 3–5 gg
        </p>
      </div>
    </section>

    {%- comment -%} ══ SCREEN 1: BELT COMPOSER ════════════════════== {%- endcomment -%}
    {%- render 'bb-screen-composer' -%}

    {%- comment -%} ══ SCREEN 2: BUNDLE REVIEW ════════════════════== {%- endcomment -%}
    {%- render 'bb-screen-review' -%}

    {%- comment -%} ══ SCREEN 3: CART ═════════════════════════════== {%- endcomment -%}
    <section id="bb-screen-cart" class="bb-screen" aria-label="Carrello">
      <div class="bb-header">
        <button class="bb-btn-icon" data-action="cart-back" aria-label="Indietro">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <div class="bb-header__title">Carrello</div>
        <div style="width:36px;"></div>
      </div>

      <div class="bb-cart bb-mt-16" id="bb-cart-bundles">
        {%- comment -%} Rendered by JS {%- endcomment -%}
      </div>

      <div style="display:flex;justify-content:space-between;padding:14px 16px 0;font-size:16px;font-weight:700;border-top:2px solid #1a1a1a;margin:0 16px;">
        <span>Totale Carrello</span>
        <span id="bb-cart-total">€ 0,00</span>
      </div>

      <p class="bb-cart__notes">
        Spedizione gratuita sopra €50 · Reso gratuito entro 30 giorni<br>
        Pagamento sicuro: Visa, Mastercard, PayPal, Apple Pay
      </p>

      <div class="bb-cta-bar">
        <button class="bb-btn-primary is-accent" data-action="go-confirm">Procedi al Checkout →</button>
        <button
          class="bb-btn-secondary"
          onclick="BundleBuilder.showScreen('selector');BundleBuilder.selectBundleType(null)"
        >
          Continua lo shopping
        </button>
      </div>
    </section>

    {%- comment -%} ══ SCREEN 4: CONFIRM ORDER ════════════════════== {%- endcomment -%}
    <section id="bb-screen-confirm" class="bb-screen" aria-label="Conferma ordine">
      <div class="bb-header">
        <button class="bb-btn-icon" data-action="cart-back" aria-label="Indietro">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <div class="bb-header__title">Conferma Ordine</div>
        <div style="width:36px;"></div>
      </div>

      <div class="bb-confirm">
        <div id="bb-confirm-bundles">
          {%- comment -%} Rendered by JS {%- endcomment -%}
        </div>

        <div class="bb-divider"></div>

        <div style="display:flex;justify-content:space-between;font-size:16px;font-weight:700;margin-bottom:16px;">
          <span>Totale da pagare</span>
          <span id="bb-confirm-total">€ —</span>
        </div>

        <div class="bb-confirm__trust">
          <div class="bb-confirm__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Pagamento sicuro
          </div>
          <div class="bb-confirm__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M4 12V4h16v8M4 20h16M12 12v8"/>
            </svg>
            Reso gratuito
          </div>
          <div class="bb-confirm__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            3–5 giorni
          </div>
        </div>

        <a href="#" class="bb-confirm__shipping">Calcola le spese di spedizione →</a>

        <button class="bb-btn-primary is-accent" data-action="checkout" style="margin-bottom:12px;">
          🔒 Vai al Pagamento
        </button>
        <button class="bb-btn-secondary" onclick="BundleBuilder.showScreen('cart')">← Continue Shopping</button>
      </div>
    </section>

    {%- comment -%} ══ SCREEN 5: ORDER CONFIRMED ══════════════════== {%- endcomment -%}
    <section id="bb-screen-confirmed" class="bb-screen" aria-label="Ordine confermato">
      <div class="bb-confirmed">
        <div class="bb-confirmed__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h2 class="bb-confirmed__title">Grazie per l'ordine!</h2>
        <p class="bb-confirmed__sub">
          Il tuo bundle personalizzato è stato aggiunto al carrello.<br>
          Riceverai una conferma via email a breve.
        </p>

        <div class="bb-confirmed__order">
          <div class="bb-confirmed__order-title">Riepilogo Set Doppio — Ordine <span id="bb-order-number"></span></div>
          <div id="bb-confirmed-summary"></div>
        </div>

        <button class="bb-btn-primary" data-action="continue">← Continue Shopping</button>
      </div>
    </section>

    {%- comment -%} ══ MODAL: Vedi indossata ══════════════════════== {%- endcomment -%}
    <div class="bb-modal" id="bb-modal-indossata" role="dialog" aria-modal="true" aria-label="Vedi indossata">
      <button class="bb-modal__close" data-close-modal="bb-modal-indossata" aria-label="Chiudi">✕</button>
      <div class="bb-modal__content">
        <img
          id="bb-worn-img"
          class="bb-modal__img"
          src="{{ section.settings.model_photo | img_url: '600x800' }}"
          data-fallback="{{ section.settings.model_photo | img_url: '600x800' }}"
          alt="Cintura indossata"
          {% unless section.settings.model_photo %}
            style="display:none"
          {% endunless %}
        >
        <div
          id="bb-worn-placeholder"
          class="bb-modal__placeholder"
          {% if section.settings.model_photo %}
            style="display:none"
          {% endif %}
        >
          <svg viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="#555" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span>Nessuna foto disponibile per questa combinazione</span>
        </div>
        <div class="bb-modal__caption">
          <strong>COMBINAZIONE ATTUALE</strong>
          <span id="bb-modal-caption-text">130cm · Fibbia Classica · Nero</span>
        </div>
      </div>
    </div>

    {%- comment -%} ══ MODAL: Vedi 360° ═══════════════════════════== {%- endcomment -%}
    <div class="bb-modal bb-modal--360" id="bb-modal-360" role="dialog" aria-modal="true" aria-label="Vedi 360°">
      <button class="bb-modal__close" data-close-modal="bb-modal-360" aria-label="Chiudi">✕</button>
      <div class="bb-modal__content">

        <div class="bb-360-viewer" id="bb-360-viewer">

          <button class="bb-360-close" data-close-modal="bb-modal-360" aria-label="Chiudi">✕</button>

          {%- comment -%} Swipe hint — fades out on first drag interaction {%- endcomment -%}
          <div class="bb-360-hint" id="bb-360-hint" aria-hidden="true">
            <div class="bb-360-swipe-icon">
              <svg viewBox="0 0 2761.93 3304.67" xmlns="http://www.w3.org/2000/svg" width="64" height="64" style="display:block">
