<script>
  /* ── Carousel configuration (from Shopify Theme Editor) ───── */
  /* URL delle immagini prodotto bundle (da Shopify CDN) — usate in riepilogo e carrello */
  window.BB_BUNDLE_IMAGES = {
    single:    {{ section.settings.img_single    | img_url: '240x240' | json | default: '""' }},
    double:    {{ section.settings.img_double    | img_url: '240x240' | json | default: '""' }},
    triple:    {{ section.settings.img_triple    | img_url: '240x240' | json | default: '""' }},
    infinity:  {{ section.settings.img_infinity  | img_url: '240x240' | json | default: '""' }},
  };
  window.BB_CAROUSEL_CONFIG = {
    buckleOrder:   {{ section.settings.buckle_order   | default: "buckle-2,buckle-1,buckle-3,buckle-4" | json }},
    strapOrder:    {{ section.settings.strap_order    | default: "strap-nero,strap-marrone,strap-cognac,strap-cuoio,strap-beige,strap-rosso,strap-verde,strap-blu,strap-grigio" | json }},
    defaultBuckle: {{ section.settings.default_buckle | default: "buckle-2" | json }},
    defaultStrap:  {{ section.settings.default_strap  | default: "strap-nero" | json }},
  };
</script>

<script>
  /*
   * SKU map — injected from Shopify Theme Editor settings.
   * Straps   : 18 variants (9 colours × 2 lengths: 130cm / 150cm)
   * Buckles  : 4 variants  (one per style)
   * Logistics: 3 internal-only items — added to every order with "_" prefix
   *            properties so Shopify hides them from customer-facing views
   *            (cart, order confirmation email) but shows them in Admin orders
   *            for warehouse/logistics use. Set them as "Draft" / unlisted
   *            products in Shopify so customers cannot find or purchase them.
   */
  window.BB_VARIANTS = {
    belt_preview_base_url: {{ section.settings.belt_preview_base_url | default: "" | json }},
    bundles: {
      single:         {{ section.settings.variant_bundle_single         | default: 0 }},
      double:         {{ section.settings.variant_bundle_double         | default: 0 }},
      triple:         {{ section.settings.variant_bundle_triple         | default: 0 }},
      infinity_base:  {{ section.settings.variant_bundle_infinity_base  | default: 0 }},
      infinity_extra: {{ section.settings.variant_bundle_infinity_extra | default: 0 }},
    },
    straps: {
      '130': {{ section.settings.variant_strap_130 | default: 0 }},
      '150': {{ section.settings.variant_strap_150 | default: 0 }},
    },
    buckles: {
      'buckle-1': {{ section.settings.variant_buckle_1 | default: 0 }},
      'buckle-2': {{ section.settings.variant_buckle_2 | default: 0 }},
      'buckle-3': {{ section.settings.variant_buckle_3 | default: 0 }},
      'buckle-4': {{ section.settings.variant_buckle_4 | default: 0 }},
    },
    logistics: {
      warranty: {{ section.settings.variant_logistics_warranty | default: 0 }},
      nfc:      {{ section.settings.variant_logistics_nfc      | default: 0 }},
      box:      {{ section.settings.variant_logistics_box      | default: 0 }},
    },
  };
  window.BB_AVAIL_MODE = {{ section.settings.unavailability_mode | default: 'grey' | json }};

  {%- comment -%}
    BB_SKU_IMAGES: mappa SKU variante → URL immagine per le foto preview delle combinazioni.
    Richiede l'handle del prodotto Shopify che contiene le 72 varianti (lunghezza+fibbia+colore).
    Ogni variante deve avere: un campo SKU compilato e un'immagine della variante assegnata.
  {%- endcomment -%}
  {%- if section.settings.belt_combo_product_handle != blank -%}
    {%- assign _bcp = all_products[section.settings.belt_combo_product_handle] -%}
    {%- if _bcp.id -%}
  window.BB_SKU_IMAGES = {
      {%- for _v in _bcp.variants -%}
        {%- if _v.sku != blank -%}
          {%- if _v.featured_image -%}
    {{ _v.sku | json }}: {{ _v.featured_image | image_url: width: 900 | prepend: 'https:' | json }},
          {%- elsif _bcp.featured_image -%}
    {{ _v.sku | json }}: {{ _bcp.featured_image | image_url: width: 900 | prepend: 'https:' | json }},
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
  };
    {%- endif -%}
  {%- endif -%}
</script>

