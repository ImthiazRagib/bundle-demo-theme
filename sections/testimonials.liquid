<section class="testimonials">
  <div class="testimonials__container">

    {%- if section.settings.badge != blank -%}
      <span class="testimonials__badge">{{ section.settings.badge }}</span>
    {%- endif -%}
    <h2 class="testimonials__heading">{{ section.settings.heading | default: "Cosa dicono i nostri clienti" }}</h2>
    {%- if section.settings.rating_summary != blank -%}
      <div class="testimonials__summary">
        <div class="testimonials__stars" aria-label="5 su 5 stelle">
          {%- for i in (1..5) -%}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- endfor -%}
        </div>
        <span class="testimonials__summary-text">{{ section.settings.rating_summary }}</span>
      </div>
    {%- endif -%}

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <article class="testimonial-card{% if block.settings.featured %} testimonial-card--featured{% endif %}" {{ block.shopify_attributes }}>
            <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} stelle su 5">
              {%- assign rating = block.settings.rating | default: 5 -%}
              {%- for i in (1..5) -%}
                <svg width="14" height="14" viewBox="0 0 24 24"
                     fill="{% if i <= rating %}currentColor{% else %}none{% endif %}"
                     stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {%- endfor -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="testimonial-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            <blockquote class="testimonial-card__quote">
              "{{ block.settings.quote }}"
            </blockquote>

            <footer class="testimonial-card__footer">
              <div class="testimonial-card__avatar" aria-hidden="true">
                {{ block.settings.name | slice: 0 }}
              </div>
              <div class="testimonial-card__author">
                <strong>{{ block.settings.name }}</strong>
                {%- if block.settings.location != blank -%}
                  <span>{{ block.settings.location }}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.verified -%}
                <span class="testimonial-card__verified">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
                    <path d="M7 1l1.5-1L10 1l1.5-.5L12 2l1.5.5-.5 1.5L14 5.5l-1 1 .5 1.5-1.5.5L12 10l-1.5.5L10 12l-1.5-.5L7 13l-1.5-.5L4 12l-1.5.5L2 10.5l-1.5-.5L1 8.5 0 7.5l.5-1.5L0 4.5l1.5-.5L2 2.5l1.5-.5L5 1l1.5.5L7 1z" fill="#b8860b" opacity=".2"/>
                    <path d="M4.5 8l2 2 4.5-4.5" stroke="#b8860b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Acquisto verificato
                </span>
              {%- endif -%}
            </footer>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 6,
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "Qualità eccellente, esattamente come descritto."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Marco R."
        },
        {
          "type": "text",
          "id": "location",
          "label": "City / location",
          "default": "Milano"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show \"verified purchase\" badge",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Feature this review (larger card)",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge label",
      "default": "Recensioni"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Cosa dicono i nostri clienti"
    },
    {
      "type": "text",
      "id": "rating_summary",
      "label": "Rating summary text",
      "default": "4.9 su 5 — basato su 340+ recensioni"
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Cintura perfetta, finalmente",
            "quote": "Ho il Double Bundle da tre mesi e non potrei essere più soddisfatto. La qualità del cuoio è eccezionale e le fibbie sono robustissime. Il processo di personalizzazione è stato divertente e intuitivo.",
            "name": "Luca M.",
            "location": "Milano",
            "verified": true,
            "featured": true
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Regalo perfetto",
            "quote": "Ho regalato il Triple Bundle a mio padre per il suo compleanno. Era commosso dalla qualità e dall'eleganza della confezione. Sicuramente riacquisterò.",
            "name": "Sofia B.",
            "location": "Roma",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Artigianalità vera",
            "quote": "Si vede subito che non è produzione industriale. Le cuciture, il cuoio, il profumo — tutto racconta di mani esperte. Con l'Infinity Bundle ho scelto 5 cinture diverse per ogni outfit.",
            "name": "Davide C.",
            "location": "Firenze",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
