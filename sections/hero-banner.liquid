<section class="hero-banner{% if section.settings.image %} hero-banner--has-image{% endif %}"
  style="{% if section.settings.image %}background-image: url('{{ section.settings.image | image_url: width: 1600, height: 900 }}');{% endif %}
         {% if section.settings.overlay_opacity > 0 %}--hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};{% endif %}
         min-height: {{ section.settings.min_height }}px;">

  <div class="hero-banner__overlay" aria-hidden="true"></div>

  <div class="hero-banner__container">
    <div class="hero-banner__content hero-banner__content--{{ section.settings.content_align }}">

      {%- if section.settings.subheading != blank -%}
        <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="hero-banner__text">{{ section.settings.text }}</p>
      {%- endif -%}

      <div class="hero-banner__actions">
        {%- if section.settings.btn_primary_label != blank -%}
          <a href="{{ section.settings.btn_primary_url | default: '/pages/bundle' }}?type=set-cinture-doppio"
             class="hero-btn hero-btn--primary">
            {{ section.settings.btn_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn_secondary_label != blank -%}
          <a href="{{ section.settings.btn_secondary_url | default: routes.collections_url }}"
             class="hero-btn hero-btn--secondary">
            {{ section.settings.btn_secondary_label }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_badges -%}
        <div class="hero-banner__trust">
          <span>✦ Artigianalità italiana</span>
          <span>✦ Spedizione 3–5 gg</span>
          <span>✦ Reso gratuito</span>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "label": "Overlay opacity (%)",
      "default": 45
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "label": "Minimum height (px)",
      "default": 600
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Artigianato Italiano dal 1982"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "La Cintura Perfetta,\nCreata da Te"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Scegli fibbia, colore e lunghezza. Componi il tuo bundle unico — Single, Double, Triple o Infinity."
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Primary button label",
      "default": "Crea il tuo Bundle →"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Secondary button label",
      "default": "Scopri le Collezioni"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "checkbox",
      "id": "trust_badges",
      "label": "Show trust badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
