<header class="site-header" role="banner">
  <div class="site-header__container">

    <!-- Mobile menu toggle -->
    <button class="site-header__menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="SiteNav">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2.5 5h15M2.5 10h15M2.5 15h15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="site-header__logo">
      {%- if section.settings.logo -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}"
             alt="{{ section.settings.logo_alt | default: shop.name }}"
             width="140" height="auto" loading="eager">
      {%- else -%}
        <span class="site-header__logo-text">
          {%- if section.settings.logo_text != blank -%}
            {{ section.settings.logo_text }}
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </span>
      {%- endif -%}
    </a>

    <!-- Desktop nav -->
    <nav class="site-header__nav" id="SiteNav" aria-label="Main navigation">
      <ul class="site-header__nav-list" role="list">
        {%- if section.settings.menu != blank -%}
          {%- for link in linklists[section.settings.menu].links -%}
            <li class="site-header__nav-item{% if link.active %} is-active{% endif %}">
              <a href="{{ link.url }}" class="site-header__nav-link">{{ link.title }}</a>
            </li>
          {%- endfor -%}
        {%- else -%}
          <li class="site-header__nav-item"><a href="{{ routes.root_url }}" class="site-header__nav-link">Home</a></li>
          <li class="site-header__nav-item"><a href="/pages/bundle" class="site-header__nav-link site-header__nav-link--cta">Crea il tuo Bundle →</a></li>
          <li class="site-header__nav-item"><a href="{{ routes.collections_url }}" class="site-header__nav-link">Collezioni</a></li>
        {%- endif -%}
      </ul>
    </nav>

    <!-- Header actions -->
    <div class="site-header__actions">
      <!-- Search -->
      <a href="{{ routes.search_url }}" class="site-header__icon" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.6"/>
          <path d="M11.5 11.5L16 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </a>

      <!-- Account -->
      <a href="{{ routes.account_url }}" class="site-header__icon" aria-label="Account">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="9" cy="6" r="3.5" stroke="currentColor" stroke-width="1.6"/>
          <path d="M2 16c0-3.3 3.1-6 7-6s7 2.7 7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </a>

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart" aria-label="Cart ({{ cart.item_count }} items)">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1h2.5l2.1 9.5h8.8l1.6-6.5H5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="7.5" cy="15.5" r="1.5" fill="currentColor"/>
          <circle cx="13.5" cy="15.5" r="1.5" fill="currentColor"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="site-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

<script>
  // Mobile menu toggle
  (function() {
    const toggle = document.querySelector('.site-header__menu-toggle');
    const nav = document.getElementById('SiteNav');
    if (!toggle || !nav) return;
    toggle.addEventListener('click', function() {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('is-open', !expanded);
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (if no image)",
      "default": "CINTURE ARTIGIANALI"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
