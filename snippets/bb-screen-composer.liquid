{{ 'bb-screen-composer.css' | asset_url | stylesheet_tag }}

{%- comment -%} ══ SCREEN 1: BELT COMPOSER ════════════════════== {%- endcomment -%}
<section id="bb-screen-composer" class="bb-screen" aria-label="Componi la cintura">
  {%- comment -%} ── Hero: full-width preview photo + wizard overlay + quick actions ── {%- endcomment -%}
  <div
    class="bb-composer-hero"
    id="bb-composer-hero"
    data-belt-preview-base="{{ section.settings.belt_preview_base_url }}"
  >
    {%- comment -%} Belt wizard tab bar overlaid at TOP of the hero photo {%- endcomment -%}
    <div id="bb-belt-wizard"></div>

    {%- comment -%} Background: belt combo photo fills entire hero area {%- endcomment -%}
    <canvas id="bb-belt-canvas" width="340" height="100" style="display:none;max-width:100%;"></canvas>
    <img
      id="bb-belt-preview-img"
      src=""
      alt="Anteprima cintura"
      class="bb-composer-hero__bg"
      style="display:none;"
    >
    <div class="bb-belt-preview__placeholder" id="bb-belt-preview-placeholder">
      Seleziona le opzioni per vedere l'anteprima
    </div>

    {%- comment -%} Bottom foot: quick action buttons stacked on right, Riepilogo hidden {%- endcomment -%}
    <div class="bb-composer-hero__foot">
      <div class="bb-quick-actions">
        <button class="bb-quick-btn" data-action="vedi-360">
          <svg
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="none"
            stroke-width="1.8"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <linearGradient id="gi2" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#e8b923"/>
                <stop offset="100%" stop-color="#b8800b"/>
              </linearGradient>
            </defs>
            <polyline points="1 4 1 10 7 10" stroke="url(#gi2)"/>
            <polyline points="23 20 23 14 17 14" stroke="url(#gi2)"/>
            <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15" stroke="url(#gi2)"/>
          </svg>
          Vedi 360°
        </button>
        <button class="bb-quick-btn" data-action="vedi-indossata">
          <svg
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="none"
            stroke-width="1.8"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <linearGradient id="gi1" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#e8b923"/>
                <stop offset="100%" stop-color="#b8800b"/>
              </linearGradient>
            </defs>
            <circle cx="12" cy="8" r="4" stroke="url(#gi1)"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="url(#gi1)"/>
          </svg>
          Vedi indossata
        </button>

        <button class="bb-quick-btn" data-action="vedi-riepilogo" style="display:none">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
            <rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/>
          </svg>
          Riepilogo
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} 2. Buckle carousel {%- endcomment -%}
  <div class="bb-section bb-section--buckle">
    <div class="bb-section-header">
      <div class="bb-section__label">
        2. Fibbia: <span id="bb-buckle-name-inline" class="bb-selection-inline-name"></span>
      </div>
      {% comment %} <span class="bb-section__counter" id="bb-buckle-nav-label"></span> {% endcomment %}
    </div>
    <div class="bb-carousel" id="bb-buckle-carousel" role="listbox" aria-label="Stile fibbia">
      {%- comment -%} Rendered by JS {%- endcomment -%}
    </div>
    <div class="bb-strap-nav">
      <button class="bb-strap-nav__btn" id="bb-buckle-prev" aria-label="Fibbia precedente">&#8592;</button>
      <button class="bb-strap-nav__btn" id="bb-buckle-next" aria-label="Fibbia successiva">&#8594;</button>
    </div>
  </div>

  {%- comment -%} 3. Strap color — vertical stacked fan {%- endcomment -%}
  <div class="bb-section bb-section--strap">
    <div class="bb-section-header">
      <div class="bb-section__label">
        3. Cintura: <span id="bb-strap-name-inline" class="bb-selection-inline-name"></span>
      </div>
      {% comment %} <span class="bb-section__counter" id="bb-strap-nav-label"></span> {% endcomment %}
      <div class="bb-length-selector" id="bb-length-selector">
        {%- comment -%} Rendered by JS {%- endcomment -%}
      </div>
    </div>
    <div class="bb-strap-carousel" id="bb-strap-carousel" role="listbox" aria-label="Colore della cintura">
      {%- comment -%} Rendered by JS as horizontal fan items {%- endcomment -%}
    </div>
    <div class="bb-strap-selected-name" id="bb-strap-color-name"></div>
    <div class="bb-strap-nav">
      <button class="bb-strap-nav__btn" id="bb-strap-prev" aria-label="Colore precedente">&#8592;</button>
      <button class="bb-strap-nav__btn" id="bb-strap-next" aria-label="Colore successivo">&#8594;</button>
    </div>
  </div>

  {%- comment -%} Bottom CTA — two buttons: back + seleziona stile fibbia {%- endcomment -%}
  <div class="bb-cta-bar bb-cta-bar--double">
    <button class="bb-btn-composer-back" data-action="composer-back">← Indietro</button>
    <button class="bb-btn-primary is-accent" data-action="add-to-set" id="bb-composer-cta">
      Seleziona uno stile di fibbia →
    </button>
  </div>

  {%- comment -%} Infinity — extra belt controls (shown only for infinity bundle type) {%- endcomment -%}
  <div id="bb-infinity-controls" style="display:none;" class="bb-infinity-bar">
    <div class="bb-infinity-bar__total" id="bb-infinity-total">Totale: € 119,99 · 4 cinture</div>
    <button class="bb-infinity-bar__add" data-action="infinity-add-belt">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Aggiungi cintura — € 19,99
    </button>
  </div>
</section>
