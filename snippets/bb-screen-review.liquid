{{ 'bb-screen-review.css' | asset_url | stylesheet_tag }}

{%- comment -%} ══ SCREEN 2: BUNDLE REVIEW ════════════════════== {%- endcomment -%}
<section id="bb-screen-review" class="bb-screen" aria-label="Riepilogo bundle">
  <div class="bb-header">
    <button class="bb-btn-icon" data-action="review-back" aria-label="Indietro">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <div class="bb-header__title" id="bb-review-title">Riepilogo Set Doppio</div>
    <div style="width:36px;"></div>
  </div>

  <div
    class="bb-progress"
    id="bb-progress-review"
    style="padding-top:14px;display:flex;align-items:center;justify-content:center;gap:6px;padding-left:16px;padding-right:16px;"
  >
    {%- comment -%} Could also be rendered by JS if desired {%- endcomment -%}
  </div>

  <div class="bb-review bb-mt-16" id="bb-review-belts">
    {%- comment -%} Rendered by JS {%- endcomment -%}
  </div>

  <div class="bb-divider" style="margin:0 16px;"></div>

  <div style="display:flex;justify-content:space-between;padding:14px 16px 0;font-size:15px;font-weight:700;">
    <span>Totale pacchetto</span>
    <span id="bb-review-total">€ —</span>
  </div>

  <div class="bb-cta-bar">
    <button class="bb-btn-primary is-accent" data-action="add-to-cart">🛒 Aggiungi al Carrello</button>
    <button class="bb-btn-secondary" data-action="review-back">Continua a modificare</button>
  </div>
</section>
