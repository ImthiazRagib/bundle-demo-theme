{% layout 'theme' %}

<div class="page-content" style="text-align:center; padding:80px 24px;">
  <div class="page-content__container" style="max-width:480px; margin:0 auto;">
    <h1 class="page-content__title">Gift Card</h1>
    <p style="font-size:28px; font-weight:800; letter-spacing:.1em; margin:24px 0 8px; font-family:monospace;">
      {{ gift_card.code | format_code }}
    </p>
    {% unless gift_card.enabled %}<p style="color:#ef4444; font-size:13px;">Expired</p>{% endunless %}
    <p style="font-size:16px; font-weight:700; margin-bottom:8px;">Balance: {{ gift_card.balance | money }}</p>
    <a href="{{ shop.url }}" class="bundle-intro__cta" style="margin-top:24px; display:inline-flex;">Shop now</a>
  </div>
</div>
