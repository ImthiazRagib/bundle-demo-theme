<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }} — Coming Soon</title>
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>
  <body style="background:var(--color-header-bg); min-height:100vh; display:flex; align-items:center; justify-content:center;">
    <div style="text-align:center; color:#fff; padding:40px 24px; max-width:480px;">
      <h1 style="font-size:36px; font-weight:800; margin-bottom:16px;">{{ shop.name }}</h1>
      <p style="color:rgba(255,255,255,.65); font-size:16px; margin-bottom:32px; line-height:1.6;">
        Stiamo preparando qualcosa di speciale. Torna presto.
      </p>
      {% form 'storefront_password' %}
        <div style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap;">
          <input type="password" name="password" placeholder="Password di accesso"
                 style="padding:11px 18px; border-radius:8px; border:1px solid rgba(255,255,255,.2); background:rgba(255,255,255,.1); color:#fff; font-size:14px; font-family:inherit; outline:none; flex:1; min-width:200px; max-width:280px;">
          <button type="submit" class="bundle-intro__cta" style="padding:11px 24px; font-size:14px;">Entra →</button>
        </div>
        {% if form.errors %}
          <p style="color:#f87171; font-size:13px; margin-top:12px;">Password errata. Riprova.</p>
        {% endif %}
      {% endform %}
    </div>
  </body>
</html>
