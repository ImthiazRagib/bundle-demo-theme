{% layout 'theme' %}

<section class="page-content">
  <div class="page-content__container">
    <h1 class="page-content__title">{{ 'templates.cart.title' | t }}</h1>

    {% if cart.item_count == 0 %}
      <p style="color: var(--color-text-muted); margin-bottom: 24px;">Il tuo carrello è vuoto.</p>
      <a href="{{ routes.root_url }}" class="bundle-intro__cta">← Continua lo Shopping</a>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <table style="width:100%; border-collapse:collapse; margin-bottom:32px;">
          <thead>
            <tr style="border-bottom:2px solid var(--color-border); text-align:left;">
              <th style="padding:12px 0; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.05em;">Prodotto</th>
              <th style="padding:12px 0; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.05em;">Qtà</th>
              <th style="padding:12px 0; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; text-align:right;">Totale</th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr style="border-bottom:1px solid var(--color-border);">
                <td style="padding:16px 0; display:flex; gap:16px; align-items:center;">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 80, height: 80 }}" alt="{{ item.title | escape }}" width="60" height="60" style="border-radius:8px; border:1px solid var(--color-border); object-fit:cover;">
                  {% endif %}
                  <div>
                    <a href="{{ item.url }}" style="font-weight:600; font-size:14px;">{{ item.product.title }}</a>
                    {% unless item.variant.title == 'Default Title' %}
                      <p style="font-size:12px; color:var(--color-text-muted);">{{ item.variant.title }}</p>
                    {% endunless %}
                    <p style="font-size:13px; color:var(--color-text-muted);">{{ item.price | money }}</p>
                  </div>
                </td>
                <td style="padding:16px 0;">
                  <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0"
                         style="width:56px; padding:6px 10px; border:1px solid var(--color-border); border-radius:6px; font-size:14px; font-family:inherit;">
                </td>
                <td style="padding:16px 0; text-align:right; font-weight:700; font-size:15px;">
                  {{ item.line_price | money }}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <div style="display:flex; justify-content:flex-end; gap:16px; flex-wrap:wrap; align-items:center; margin-bottom:24px;">
          <button name="update" type="submit" style="background:transparent; border:1px solid var(--color-border); color:var(--color-text-muted); padding:10px 20px; border-radius:6px; font-size:13px; font-family:inherit;">
            Aggiorna Carrello
          </button>
          <div style="font-size:18px; font-weight:800;">
            Totale: {{ cart.total_price | money }}
          </div>
        </div>

        <div style="display:flex; justify-content:flex-end;">
          <a href="/checkout" class="bundle-intro__cta" style="font-size:15px; padding:14px 32px;">
            🔒 Procedi al Checkout →
          </a>
        </div>
      </form>
    {% endif %}
  </div>
</section>
